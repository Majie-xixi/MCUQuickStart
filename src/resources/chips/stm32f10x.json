      "hxtal_hz": 8000000,
      "sim_dll": "SARMCM3.DLL",
      "target_dll": "SARMCM3.DLL",
      "sim_dlg_dll": "DCM.DLL",
      "target_dlg_dll": "TCM.DLL",
      "dlg_arguments": "-pCM3"
